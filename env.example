TELEGRAM_BOT_TOKEN=123456789:ABC...

# Vergul bilan ajratilgan chat ID lar — bot va Netlify booking-notify ham shu ro‘yxatga yozadi.
BOOKING_NOTIFY_CHAT_IDS=123456789,-1001234567890

# --- Netlify webhook bot (telegram-bot funktsiyasi) ---
# Upstash Redis (https://upstash.com) — serverless sessiya uchun bepul rejadan boshlash mumkin.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Tasodifiy uzun qator (masalan openssl rand -hex 32). Netlify Environment ga ham, set-webhook ham.
TELEGRAM_WEBHOOK_SECRET=

# Faqat npm run set-webhook uchun — deploy qilingan sayt URL i:
# WEBHOOK_URL=https://SIZNING.netlify.app/.netlify/functions/telegram-bot
